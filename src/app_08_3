import * as THREE from "three";
import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";

class ThreeJSContainer {
    private scene!: THREE.Scene;
    private light!: THREE.Light;

    constructor() {

    }

    // 画面部分の作成(表示する枠ごとに)*
    public createRendererDOM = (width: number, height: number, cameraPos: THREE.Vector3) => {
        const renderer = new THREE.WebGLRenderer();
        renderer.setSize(width, height);
        renderer.setClearColor(new THREE.Color(0x495ed));
        renderer.shadowMap.enabled = true; //シャドウマップを有効にする

        //カメラの設定
        const camera = new THREE.PerspectiveCamera(75, width / height, 0.1, 1000);
        camera.position.copy(cameraPos);
        camera.lookAt(new THREE.Vector3(0, 0, 0));

        const orbitControls = new OrbitControls(camera, renderer.domElement);

        this.createScene();
        // 毎フレームのupdateを呼んで，render
        // reqestAnimationFrame により次フレームを呼ぶ
        const render: FrameRequestCallback = (_time) => {
            orbitControls.update();

            renderer.render(this.scene, camera);
            requestAnimationFrame(render);
        }
        requestAnimationFrame(render);

        renderer.domElement.style.cssFloat = "left";
        renderer.domElement.style.margin = "10px";
        return renderer.domElement;
    }

    // シーンの作成(全体で1回)
    private createScene = async () => {
        this.scene = new THREE.Scene();

        const axesBarLength = 10.0;
        this.scene.add(new THREE.AxesHelper(axesBarLength))

        //ライトの設定
        this.light = new THREE.DirectionalLight(0xffffff);
        const lvec = new THREE.Vector3(1, 1, 1).normalize();
        this.light.position.set(lvec.x, lvec.y, lvec.z);
        this.scene.add(this.light);

        const objPath = "./src/dice.obj";
        const objText = await readFile(objPath);
        const verticesArray: number[] = [];
        const uvsArray: number[] = [];
        let mtlFileName = "";
        const faceVertices: string[] = [];

        const objLines = objText.split("\n");
        for (let i = 0; i < objLines.length; i++) {
            const line = objLines[i].trim();
            if (line.startsWith("mtllib")) {
                const parts = line.split(/\s+/);
                if (parts.length > 1) {
                    mtlFileName = parts[1];
                }
            } else if (line.startsWith("v ")) {
                const parts = line.split(/\s+/);
                verticesArray.push(parseFloat(parts[1]));
                verticesArray.push(parseFloat(parts[2]));
                verticesArray.push(parseFloat(parts[3]));
            } else if (line.startsWith("vt ")) {
                //UV座標
                const parts = line.split(/\s+/);
                uvsArray.push(parseFloat(parts[1]));
                uvsArray.push(parseFloat(parts[2]));
            } else if (line.startsWith("f ")) {
                const parts = line.split(/\s+/);
                for (let j = 1; j < parts.length; j++) {
                    faceVertices.push(parts[j]);
                }
            }
        }

        let textureFileName = "diceTexture.png";
        if (mtlFileName !== "dice.mtl") {
            const mtlPath = "./src/" + mtlFileName;
            const mtlText = await readFile(mtlPath);

            const mtlLines = mtlText.split("\n");
            for (let i = 0; i < mtlLines.length; i++) {
                const line = mtlLines[i].trim();
                if (line.startsWith("map_Kd ")) {
                    const parts = line.split(/\s+/);
                    textureFileName = parts[1];
                    break;
                }
            }
        }
        const finalVertices: number[] = [];
        const finalUvs: number[] = [];
        const finalIndices: number[] = [];
        const vertexMap: { [key: string]: number } = {};
        let uniqueIndexCounter = 0;

        for (let i = 0; i < faceVertices.length; i++) {
            const faceVertexStr = faceVertices[i];

            if (vertexMap[faceVertexStr] !== undefined) {
                finalIndices.push(vertexMap[faceVertexStr]);
            } else {
                const indicesParts = faceVertexStr.split("/");
                const vIdx = parseInt(indicesParts[0], 10) - 1;
                finalVertices.push(verticesArray[vIdx * 3]);
                finalVertices.push(verticesArray[vIdx * 3 + 1]);
                finalVertices.push(verticesArray[vIdx * 3 + 2]);
                if (indicesParts.length > 1 && indicesParts[1] !== "") {
                    const vtIdx = parseInt(indicesParts[1], 10) - 1;
                    finalUvs.push(uvsArray[vtIdx * 2]);
                    finalUvs.push(uvsArray[vtIdx * 2 + 1]);
                } else {
                    finalUvs.push(0.0, 0.0);
                }
                vertexMap[faceVertexStr] = uniqueIndexCounter;
                finalIndices.push(uniqueIndexCounter);
                uniqueIndexCounter++;
            }
        }

        const geometry = new THREE.BufferGeometry();
        geometry.setAttribute("position", new THREE.BufferAttribute(new Float32Array(finalVertices), 3));
        geometry.setAttribute("uv", new THREE.BufferAttribute(new Float32Array(finalUvs), 2));
        geometry.setIndex(finalIndices);
        geometry.computeVertexNormals();

        //読み込み
        const material = new THREE.MeshBasicMaterial();
        if (textureFileName !== "dice.mtl") {
            const textureLoader = new THREE.TextureLoader();
            const texture = textureLoader.load("./src/" + textureFileName);
            material.map = texture;
        }

        const mesh = new THREE.Mesh(geometry, material);
        this.scene.add(mesh);

        // 毎フレームのupdateを呼んで，更新
        // reqestAnimationFrame により次フレームを呼ぶ
        const update: FrameRequestCallback = (_time) => {

            requestAnimationFrame(update);
        }
        requestAnimationFrame(update);
    }
}

async function readFile(path: string): Promise<string> {
    return new Promise((resolve => {
        const loader = new THREE.FileLoader();
        loader.load(path, (data) => {
            if (typeof data === "string") {
                resolve(data);
            } else {
                const decoder = new TextDecoder('utf-8');
                const decodedString = decoder.decode(data);
                resolve(decodedString);
            }
        },
        );
    }));
}

window.addEventListener("DOMContentLoaded", init);

function init() {
    const container = new ThreeJSContainer();

    const viewport = container.createRendererDOM(640, 480, new THREE.Vector3(0, 0, 3));
    document.body.appendChild(viewport);
}